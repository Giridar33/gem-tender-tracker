# =============================================================
# GEM Tender Tracker — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit the .env file.
# =============================================================

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string (Render / Supabase / local)
DATABASE_URL=postgresql://user:password@localhost:5432/gem_tenders

# ── Scraper ──────────────────────────────────────────────────
SCRAPE_BASE_URL=https://bidplus.gem.gov.in/all-bids
# Maximum pages to scrape per run (set lower for testing)
MAX_PAGES=50
# Seconds to wait between page requests (politeness delay)
REQUEST_DELAY=1.5
# Request timeout in seconds
REQUEST_TIMEOUT=15

# ── Scheduler ────────────────────────────────────────────────
# Cron expression for APScheduler (default: daily at 2 AM UTC)
SCHEDULE_CRON=0 2 * * *

# ── API ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Bonus AI/ML (optional) ──────────────────────────────────
# Only required if you enable the AI enrichment module
GEMINI_API_KEY=your-gemini-api-key-here

# ── Streamlit Dashboard ───────────────────────────────────────
# Set this to your live Railway API URL in Streamlit Cloud secrets
API_BASE_URL=https://your-app.up.railway.app
